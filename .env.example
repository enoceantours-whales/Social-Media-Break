# ---------------------------------------------------------------------------
# Social Media Break — environment configuration
# Copy this file to `.env` and fill in your keys. Never commit `.env`.
# ---------------------------------------------------------------------------

# Anthropic Claude API key — powers AI caption generation.
# Get one at https://console.anthropic.com/
# If this is omitted, the app runs in DEMO mode and returns sample captions
# so you can click through the whole flow without a key.
ANTHROPIC_API_KEY=

# Buffer API key — handles scheduling to Instagram, Facebook, Twitter/X, and
# LinkedIn. This uses Buffer's NEW GraphQL API (https://api.buffer.com).
# Create a Personal Key under Buffer → Settings → Developers → API (New).
# If omitted, scheduling runs in DEMO mode (no real posts are sent).
BUFFER_ACCESS_TOKEN=

# Optional: pin specific Buffer channel IDs per brand + network — handy when
# both brands have channels on the same network and you want to be explicit.
# Find your IDs by calling GET /api/profiles once the token is set.
# Format is "<network>:<channel_id>" comma-separated. Leave blank to let the
# app auto-match channels to brands by service + brand name.
BUFFER_PROFILES_ENOCEAN=
BUFFER_PROFILES_SMP=

# ---------------------------------------------------------------------------
# Media hosting — Vercel Blob (recommended)
# Buffer attaches media from a public URL. With a Blob store connected, the
# browser uploads the photo/video directly to Blob (no size limit through the
# server) and that public URL is sent to Buffer.
#
# In Vercel: Storage → Create → Blob, then "Connect" it to this project — Vercel
# injects BLOB_READ_WRITE_TOKEN automatically. For local `vercel dev`, run
# `vercel env pull` to fetch it. Without it, posts schedule as text.
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=
