# ---------------------------------------------------------------------------
# Social Media Break — environment configuration
# Copy this file to `.env` and fill in your keys. Never commit `.env`.
# ---------------------------------------------------------------------------

# Anthropic Claude API key — powers AI caption generation.
# Get one at https://console.anthropic.com/
# If this is omitted, the app runs in DEMO mode and returns sample captions
# so you can click through the whole flow without a key.
ANTHROPIC_API_KEY=

# Buffer API access token — handles scheduling to Instagram, Facebook,
# Twitter/X, and LinkedIn. Create one at https://buffer.com/developers/apps
# If omitted, scheduling runs in DEMO mode (no real posts are sent).
BUFFER_ACCESS_TOKEN=

# Optional: pin specific Buffer profile (channel) IDs per brand + network.
# Find your IDs by calling GET /api/profiles once the token is set.
# Format is "<network>:<profile_id>" comma-separated. Leave blank to let the
# app auto-match profiles to brands by service name.
BUFFER_PROFILES_ENOCEAN=
BUFFER_PROFILES_SMP=

# ---------------------------------------------------------------------------
# Google Drive media hosting (optional)
# Buffer attaches media from a public URL. With these set, uploaded files are
# pushed to Drive, shared "anyone with link", and that URL is sent to Buffer.
# If omitted, posts are scheduled as text (or you can paste your own media URL).
#
# Setup:
#   1. Create a Google Cloud service account and enable the Drive API.
#   2. Create a JSON key for it.
#   3. In Google Drive, create a folder and share it (Editor) with the service
#      account's email — then put that folder's ID in GOOGLE_DRIVE_FOLDER_ID.
# ---------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the JSON key's private_key value. Keep the literal \n escapes — the app
# restores real newlines at runtime. Wrap in quotes.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Drive folder (shared with the service account) to upload into.
GOOGLE_DRIVE_FOLDER_ID=
